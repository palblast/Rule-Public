[custom]
; ====================================================================
; 融合版自定义订阅转换配置文件 (Clash.ini)
; 核心特性：吸取 ACL4SSR 境内直连分流优势 + Blackmatrix7 国际精细化规则优势
; 完美保留并增强了不同国家与地区节点的正则表达式分组逻辑
; ====================================================================

; --------------------------------------------------------------------
; 一、 策略组定义 (Proxy Groups)
; --------------------------------------------------------------------

; 核心控制策略组
custom_proxy_group=🚀 节点选择`select`[]♻️ 自动选择`[]🇭🇰 香港节点`[]🇹🇼 台湾节点`[]🇯🇵 日本节点`[]🇸🇬 新加坡节点`[]🇺🇸 美国节点`[]🇪🇺 欧洲节点`[]🇰🇷 韩国节点`[]🌍 剩余节点`[]DIRECT

; 延迟测试自动选择组
custom_proxy_group=♻️ 自动选择`url-test`.*`http://www.gstatic.com/generate_204`300,,50

; 国际特定应用与媒体策略组 (利用 Blackmatrix7 规则进行分流精准投放)
custom_proxy_group=📲 电报消息`select`[]🚀 节点选择`[]🇭🇰 香港节点`[]🇸🇬 新加坡节点`[]🇺🇸 美国节点`[]DIRECT
custom_proxy_group=🎬 奈飞视频`select`[]🚀 节点选择`[]🇭🇰 香港节点`[]🇹🇼 台湾节点`[]🇯🇵 日本节点`[]🇸🇬 新加坡节点`[]🇺🇸 美国节点`[]🌍 剩余节点
custom_proxy_group=📺 哔哩哔哩`select`[]DIRECT`[]🇭🇰 香港节点`[]🇹🇼 台湾节点
custom_proxy_group=🎵 国际媒体`select`[]🚀 节点选择`[]🇭🇰 香港节点`[]🇹🇼 台湾节点`[]🇯🇵 日本节点`[]🇸🇬 新加坡节点`[]🇺🇸 美国节点
custom_proxy_group=🌍 海外流媒体`select`[]🚀 节点选择`[]🇭🇰 香港节点`[]🇺🇸 美国节点
custom_proxy_group=🍎 苹果服务`select`[]DIRECT`[]🚀 节点选择`[]🇭🇰 香港节点`[]🇺🇸 美国节点
custom_proxy_group=💻 微软服务`select`[]DIRECT`[]🚀 节点选择
custom_proxy_group=🚫 广告拦截`select`[]REJECT`[]DIRECT

; --------------------------------------------------------------------
; 二、 节点正则表达式分组 (地区过滤保留并增强)
; --------------------------------------------------------------------
custom_proxy_group=🇭🇰 香港节点`select`(?i)港|hk|hongkong|hong_kong|hong kong
custom_proxy_group=🇹🇼 台湾节点`select`(?i)台|tw|taiwan|tai_wan|tai wan
custom_proxy_group=🇯🇵 日本节点`select`(?i)日|jp|japan|ja_pan|ja pan
custom_proxy_group=🇸🇬 新加坡节点`select`(?i)新|sg|singapore|singa_pore|singa pore
custom_proxy_group=🇺🇸 美国节点`select`(?i)美|us|unitedstates|united_states|united states
custom_proxy_group=🇰🇷 韩国节点`select`(?i)韩|kr|korea|ko_rea|ko rea
custom_proxy_group=🇪🇺 欧洲节点`select`(?i)欧|eu|uk|de|fr|gb|germany|france|united_kingdom
custom_proxy_group=🌍 剩余节点`select`.*

; --------------------------------------------------------------------
; 三、 规则集分流配置 (Ruleset)
; 排序逻辑：隐私广告 -> 细分应用 -> 全球通用 -> 境内直连 -> 最终匹配
; --------------------------------------------------------------------

; 1. 隐私与广告拦截 (Blackmatrix7 优势)
ruleset=🚫 广告拦截,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Privacy/Privacy.list
ruleset=🚫 广告拦截,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Advertising/Advertising.list

; 2. 国际精细化应用与流媒体 (Blackmatrix7 优势)
ruleset=📲 电报消息,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Telegram/Telegram.list
ruleset=🎬 奈飞视频,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Netflix/Netflix.list
ruleset=📺 哔哩哔哩,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/BiliBili/BiliBili.list
ruleset=🎵 国际媒体,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/YouTube/YouTube.list
ruleset=🎵 国际媒体,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Disney/Disney.list
ruleset=🎵 国际媒体,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Spotify/Spotify.list
ruleset=🌍 海外流媒体,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/GlobalMedia/GlobalMedia.list

; 3. 基础系统厂商优化 (Blackmatrix7 优势)
ruleset=🍎 苹果服务,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Apple/Apple.list
ruleset=💻 微软服务,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Microsoft/Microsoft.list

; 4. 全球通用代理规则 (Blackmatrix7 优势)
ruleset=🚀 节点选择,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Global/Global.list

; 5. 境内高能直连与局域网路由 (ACL4SSR 绝对优势)
ruleset=DIRECT,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/LocalAreaNetwork.list
ruleset=DIRECT,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/ChinaDomain.list
ruleset=DIRECT,https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/ChinaIp.list

; 6. 兜底匹配规则
ruleset=🚀 节点选择,[]MATCH
